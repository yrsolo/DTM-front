{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@dtm/schema/*": ["../../packages/schema/*"],
      "@dtm/workbench-inspector": ["../../packages/workbench-inspector/src/public.ts"],
      "@dtm/workbench-contracts": ["../../packages/workbench-contracts/src/index.ts"],
      "@dtm/workbench-source-analysis": ["../../packages/workbench-source-analysis/src/public.ts"]
    }
  },
  "include": ["src"]
}
