{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/dtm/snapshot.v1.schema.json",
  "title": "SnapshotV1",
  "type": "object",
  "required": ["meta", "people", "tasks"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "generatedAt"],
      "properties": {
        "version": { "type": "string", "const": "v1" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "hash": { "type": "string" }
      },
      "additionalProperties": false
    },
    "people": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "position": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "ownerId": { "type": ["string", "null"] },
          "ownerName": { "type": ["string", "null"] },
          "brand": { "type": ["string", "null"] },
          "customer": { "type": ["string", "null"] },
          "format_": { "type": ["string", "null"] },
          "type": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "start": { "type": "string", "format": "date" },
          "end": { "type": "string", "format": "date" },
          "nextDue": { "type": ["string", "null"], "format": "date" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "groupId": { "type": "string" },
          "deps": { "type": "array", "items": { "type": "string" } },
          "links": {
            "type": "object",
            "properties": {
              "sheetRowUrl": { "type": ["string", "null"] },
              "externalUrl": { "type": "string" },
              "self": { "type": "string" }
            },
            "additionalProperties": false
          },
          "notes": { "type": "string" },
          "history": { "type": ["string", "null"] },
          "attachments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "mime", "kind", "sizeBytes", "status"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "mime": { "type": "string" },
                "kind": { "type": "string" },
                "sizeBytes": { "type": "number" },
                "status": { "type": "string" },
                "uploadedAt": { "type": ["string", "null"], "format": "date-time" },
                "capabilities": { "type": "array", "items": { "type": "string" } },
                "meta": {
                  "type": "object",
                  "properties": {
                    "preview": { "type": ["string", "null"] }
                  },
                  "additionalProperties": false
                },
                "links": {
                  "type": "object",
                  "properties": {
                    "view": { "type": ["string", "null"] },
                    "download": { "type": ["string", "null"] }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "hash": { "type": ["string", "null"] },
          "revision": { "type": ["string", "null"] },
          "milestones": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "status"],
              "properties": {
                "type": { "type": "string" },
                "planned": { "type": "string", "format": "date" },
                "actual": { "type": ["string", "null"], "format": "date" },
                "status": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "enums": {
      "type": "object",
      "properties": {
        "status": { "type": "object", "additionalProperties": { "type": "string" } },
        "statusGroups": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "milestoneType": { "type": "object", "additionalProperties": { "type": "string" } },
        "milestoneStatus": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
